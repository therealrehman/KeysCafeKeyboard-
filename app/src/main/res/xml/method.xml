<?xml version="1.0" encoding="utf-8"?>
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.keys.cafe.keyboard.settings.SettingsActivity"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/keyboard_name">

    <subtype
        android:label="@string/subtype_en_us"
        android:languageTag="en-US"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard" />

    <subtype
        android:label="@string/subtype_de"
        android:languageTag="de-DE"
        android:imeSubtypeLocale="de_DE"
        android:imeSubtypeMode="keyboard" />

    <subtype
        android:label="@string/subtype_fr"
        android:languageTag="fr-FR"
        android:imeSubtypeLocale="fr_FR"
        android:imeSubtypeMode="keyboard" />

</input-method>
